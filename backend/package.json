{
  "name": "rd-weather-backend",
  "version": "1.1.0",
  "description": "Backend para Dashboard Climático de la República Dominicana",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:html": "vitest run --coverage",
    "test:report": "node scripts/generate-report.js",
    "test:bdd": "cucumber-js --config cucumber.config.js",
    "test:bdd:html": "cucumber-js --config cucumber.config.js --format html:reports/cucumber-report.html"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "axios-mock-adapter": "^1.22.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "vitest": "^4.1.9"
  }
}
