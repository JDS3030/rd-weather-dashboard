PORT=3001
FRONTEND_URL=http://localhost:5173

# Fuentes de datos: Open-Meteo (gratis, sin clave) + ONAMET
# No se requiere ninguna API key para el clima

# Simular alertas de ONAMET (true/false)
ONAMET_SIMULATE_EMERGENCY=false
ONAMET_SIMULATE_WATCH=false

# Twilio para WhatsApp (opcional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Contactos de emergencia (separados por coma, opcional)
EMERGENCY_CONTACTS=whatsapp:+1809XXXXXXX,whatsapp:+1829XXXXXXX

NODE_ENV=development
