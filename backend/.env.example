PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── WeatherAPI.com (fuente primaria) ─────────────────────────────────────────
# Obtén tu clave en: https://www.weatherapi.com/my/ → API Key
# Plan gratuito: 1,000,000 llamadas/mes, incluye pronóstico de 3 días y UV
# Si no se configura o falla, el sistema usará automáticamente Open-Meteo como respaldo.
WEATHERAPI_KEY=your_weatherapi_key_here

# ─── Fuente de respaldo: Open-Meteo (gratis, sin clave) + ONAMET ──────────────

# Simular alertas de ONAMET (true/false)
ONAMET_SIMULATE_EMERGENCY=false
ONAMET_SIMULATE_WATCH=false

# Twilio para WhatsApp (opcional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Contactos de emergencia (separados por coma, opcional)
EMERGENCY_CONTACTS=whatsapp:+1809XXXXXXX,whatsapp:+1829XXXXXXX

NODE_ENV=development
